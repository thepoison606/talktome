{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Talktome Server",
  "version": "1.0.0",
  "identifier": "com.talktome.server",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1430",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Talktome Server",
        "width": 760,
        "height": 620,
        "minWidth": 620,
        "minHeight": 360,
        "visible": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "closable": true,
        "minimizable": false,
        "maximizable": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/talktome-server"
    ],
    "resources": [
      "binaries/better_sqlite3.node",
      "binaries/mediasoup-worker*"
    ]
  }
}
