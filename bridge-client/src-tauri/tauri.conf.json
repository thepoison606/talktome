{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Talk To Me Bridge",
  "version": "0.1.0",
  "identifier": "com.talktome.bridge",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Talk To Me Bridge",
        "width": 820,
        "height": 820,
        "minWidth": 680,
        "minHeight": 620,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg"
    ]
  }
}
