{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Talk To Me Bridge",
  "version": "0.1.0",
  "identifier": "com.talktome.bridge",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Talk To Me Bridge",
        "width": 820,
        "height": 680,
        "minWidth": 680,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
